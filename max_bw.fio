[global]
# Use the fastest I/O engine available on Linux 6.8+
ioengine=io_uring
direct=1
# Avoid page cache
invalidate=1
# Group all jobs into a single report
group_reporting=1
# Run for a fixed time regardless of size
time_based=1
runtime=60
# Ensure we aren't just reading zeros (some controllers compress)
refill_buffers=1
# Do not repeat random patterns for true randomness
randrepeat=0
# Pin all jobs to NUMA node 0 where the NVMe is attached
cpus_allowed=0-15
# Maximize per-job queue depth
iodepth=128
# Use huge pages if available (optional, remove if not supported)
;hipri=0

# ============================================================
# MAXIMUM SEQUENTIAL READ BANDWIDTH (Raw Device - SAFE)
# Tests sequential read directly on the NVMe device.
# This is READ-ONLY and will not modify your data.
# Run with: sudo fio max_bw.fio --section=seq_read_raw
# ============================================================
[seq_read_raw]
filename=/dev/nvme0n1
rw=read
bs=1M
numjobs=8
iodepth=128
stonewall

# ============================================================
# MAXIMUM SEQUENTIAL WRITE BANDWIDTH (Raw Device - DESTRUCTIVE)
# WARNING: This will DESTROY ALL DATA on /dev/nvme0n1.
# Only run this if the device is empty or you don't care about data.
# Run with: sudo fio max_bw.fio --section=seq_write_raw
# ============================================================
[seq_write_raw]
filename=/dev/nvme0n1
rw=write
bs=1M
numjobs=8
iodepth=128
# Force overwrite any existing data
;unlink=0
stonewall

# ============================================================
# MAXIMUM RANDOM READ IOPS (Raw Device - SAFE)
# Tests 4K random read directly on the NVMe device.
# This is READ-ONLY.
# Run with: sudo fio max_bw.fio --section=rand_read_raw
# ============================================================
[rand_read_raw]
filename=/dev/nvme0n1
rw=randread
bs=4K
numjobs=16
iodepth=256
stonewall

# ============================================================
# SEQUENTIAL READ BANDWIDTH (Filesystem - SAFE)
# Tests sequential read through the mounted ext4 filesystem.
# Slightly lower numbers than raw device due to filesystem overhead.
# Run with: fio max_bw.fio --section=seq_read_file
# ============================================================
[seq_read_file]
directory=/home/jinu/workspace/gds-llm-analysis
filename=fio-test-file
rw=read
bs=1M
numjobs=8
iodepth=128
# Create a 100 GB test file (per job, but we use 1 job with size or split)
size=50G
stonewall

# ============================================================
# SEQUENTIAL WRITE BANDWIDTH (Filesystem - SAFE)
# Tests sequential write through the mounted ext4 filesystem.
# Run with: fio max_bw.fio --section=seq_write_file
# ============================================================
[seq_write_file]
directory=/home/jinu/workspace/gds-llm-analysis
filename=fio-test-file
rw=write
bs=1M
numjobs=8
iodepth=128
size=50G
# Remove test file after run
unlink=1
stonewall

# ============================================================
# RANDOM READ IOPS (Filesystem - SAFE)
# Tests 4K random read through the mounted ext4 filesystem.
# Run with: fio max_bw.fio --section=rand_read_file
# ============================================================
[rand_read_file]
directory=/home/jinu/workspace/gds-llm-analysis
filename=fio-test-file
rw=randread
bs=4K
numjobs=16
iodepth=256
size=50G
stonewall
